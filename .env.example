# ── Chain ────────────────────────────────────────────────────────────────────
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHERSCAN_API_KEY=

# ── Keys ─────────────────────────────────────────────────────────────────────
# Deployer owns ZerkRWA's allowlist and ZerkBook's zone slot.
DEPLOYER_PRIVATE_KEY=
# Desk A is the buyer (holds USDC). Desk B is the seller (holds tT-BILL).
DESK_A_PRIVATE_KEY=
DESK_B_PRIVATE_KEY=
# The blind keeper. Needs gas only — it never holds tokens and can never read an order.
MATCHER_PRIVATE_KEY=

# ── Matcher tuning ───────────────────────────────────────────────────────────
MATCHER_POLL_MS=12000
MATCHER_DECRYPT_ATTEMPTS=10
MATCHER_DECRYPT_BACKOFF_MS=6000
# Optional override; normally read from deployments/11155111.json via sync-abi.
ZERK_BOOK_ADDRESS=

# ── Sepolia e2e test ─────────────────────────────────────────────────────────
# Set to 1 to un-skip test/e2e.sepolia.test.ts. It spends real Sepolia gas.
RUN_SEPOLIA_E2E=
